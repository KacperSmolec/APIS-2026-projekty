# Skopiuj ten plik do .env i uzupełnij wartości.

# Klucz API Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=tu_wklej_swoj_klucz

# Model (domyślnie gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Parametry generacji
TEMPERATURA=0.4
TOP_P=0.9
TOP_K=40
MAKS_TOKENOW=1024

# Budżet tokenów kontekstu (kontrola długości rozmowy)
BUDZET_KONTEKSTU=3000
