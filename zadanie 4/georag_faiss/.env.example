# Skopiuj do .env i uzupełnij.

# Klucz API Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=tu_wklej_swoj_klucz

# Modele
MODEL_LLM=gemini-2.5-flash
MODEL_EMB=gemini-embedding-001
WYMIAR_EMB=768

# Chunking
DLUGOSC_FRAGMENTU=180
ZAKLADKA_ZDAN=2

# Retrieval / generacja
LICZBA_FRAGMENTOW=4
TEMPERATURA=0.2
