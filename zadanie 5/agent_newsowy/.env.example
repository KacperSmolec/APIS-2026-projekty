# Skopiuj do .env i uzupełnij.

# Klucz API Google Gemini (wymagany) — https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_wklej_swoj_klucz

# Klucz NewsAPI (opcjonalny) — https://newsapi.org/
# Bez niego agent korzysta z darmowego fallbacku Google News RSS.
NEWSAPI_KEY=

# Model i parametry
MODEL_LLM=gemini-2.5-flash
TEMPERATURA=0.3
LICZBA_ARTYKULOW=5
MAKS_ITERACJI=8
